# Copy this to .env and fill in your values
# .env is gitignored — never commit it

TZ=America/Denver
HOSTNAME=raspberrypi
DOMAIN=ct.home

# Site directories and hostnames (add more as you add services)
# MAIN_SITE_DIR: set by bootstrap.sh — path where site files are served from
MAIN_SITE_DIR=
MAIN_SITE_HOST=conspicuoustechnologist.ct.home

# Pi-hole
# PI_IP: your Pi's static IP (run: hostname -I)
PI_IP=
# PIHOLE_WEBPASSWORD: admin UI password
PIHOLE_WEBPASSWORD=
PIHOLE_HOST=pihole.ct.home

# Per-service IPs (default to PI_IP if not set)
# MAIN_SITE_IP: IP for main site DNS record (leave blank to use PI_IP)
MAIN_SITE_IP=
